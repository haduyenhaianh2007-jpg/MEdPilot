# ============ PATHS ============
DISEASES_JSON=database/data/diseases_data.json
DB_PATH=chroma_db

# ============ OLLAMA ============
OLLAMA_URL=http://localhost:11435/api/chat
OLLAMA_MODEL=qwen2.5:latest

# ============ CHAT SERVER ============
CHAT_SERVER_HOST=0.0.0.0
CHAT_SERVER_PORT=8001
CHAT_API_URL=http://localhost:8001/v1/chat/completions

# ============ BACKEND ============
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=True

# ============ EMBEDDING ============
# ⚡ ULTRA-LIGHTWEIGHT: 22MB (vs 120MB)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=4
TOP_K=1

# ============ LLM ============
TEMPERATURE=0.7
MAX_TOKENS=200
NUM_PREDICT=400
NUM_CTX=2048
TIMEOUT=45
LOG_LEVEL=INFO

# ============ MEMORY OPTIMIZATION ============
ENABLE_MODEL_POOLING=True
ENABLE_LAZY_LOADING=True
MODEL_CACHE_SIZE=30

# ============ RESOURCE LIMITS ============
# Force CPU-only (safer for mixed load)
OLLAMA_NUM_GPU=0
# Maximum context to process
OLLAMA_MAX_LOADED_MODELS=1
# Garbage collection interval
GC_INTERVAL=1000